# PostgreSQL connection — update with your local credentials
DATABASE_URL=postgresql://urvilnaik@localhost:5432/ens_db

# Model storage directory
MODEL_DIR=./models

# Minimum labeled rows before personal model is trained
PERSONAL_MODEL_MIN_ROWS=30

# Welford baseline — no longer uses EMA alpha (kept for config compatibility)
BASELINE_ALPHA=0.1

# OpenWeatherMap API key — required for weather as a determinant feature
# Get a free key at https://openweathermap.org/api
# Leave blank to run without weather (neutral defaults will be used)
WEATHER_API_KEY=your_openweathermap_api_key_here
